@model SessaoTreino
@{
    var allExercises = (List<Exercicio>)ViewBag.AllExercises;
    var grouped = allExercises.GroupBy(e => e.MuscleGroup?.Name ?? "Outros");
}
<html>
<head>
    <title>@Model.Name - MuscleHelper</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
        body { background-color: #0e1116; color: #f1f1f1; font-family: 'Inter', -apple-system, sans-serif; }
        .navbar-mw { background-color: #181b21; border-bottom: 2px solid #F5D10D; padding: 18px 32px; }
        .logo { color: #F5D10D; font-weight: 900; font-size: 24px; letter-spacing: 2px; text-decoration: none; }
        .navbar-mw a { color: #ddd; text-decoration: none; margin-left: 24px; font-weight: 600; }
        .navbar-mw a:hover { color: #F5D10D; }
        .page-title { font-weight: 800; font-size: 28px; margin: 28px 0 4px; }
        .page-title span { color: #F5D10D; }
        .section-title { color: #F5D10D; text-transform: uppercase; letter-spacing: 3px; font-weight: 700; border-left: 4px solid #F5D10D; padding-left: 12px; margin: 28px 0 16px; font-size: 14px; }
        .ex-row { background-color: #1c2027; border: 1px solid #2a2f38; border-radius: 10px; padding: 16px 20px; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; }
        .ex-row:hover { border-color: #F5D10D; }
        .ex-name { font-weight: 700; }
        .ex-meta { color: #9aa0a6; font-size: 13px; }
        .pill { display:inline-block; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; }
        .pill-sets { background:#23304a; color:#7cb1ff; }
        .pill-load { background:#1f3a26; color:#52d27a; }
        .add-panel { background-color: #1c2027; border: 1px solid #2a2f38; border-radius: 12px; padding: 24px; margin-top: 10px; }
        .add-panel h5 { color: #F5D10D; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; font-size: 13px; margin-bottom: 16px; }
        label { color: #F5D10D; font-weight: 700; text-transform: uppercase; font-size: 11px; letter-spacing: 1px; margin-bottom: 4px; }
        .form-control, .form-select { background-color: #0e1116; color: #fff; border: 1px solid #2a2f38; border-radius: 8px; }
        .form-control:focus, .form-select:focus { background-color: #0e1116; color: #fff; border-color: #F5D10D; box-shadow: 0 0 0 .15rem rgba(245,209,13,.25); }
        .btn-mw { background-color: #F5D10D; color: #0e1116; font-weight: 700; border: none; }
        .btn-mw:hover { background-color: #ffe14a; color: #0e1116; }
        .btn-outline-mw { background: transparent; color: #F5D10D; border: 1px solid #F5D10D; font-weight: 700; }
        .btn-outline-mw:hover { background-color: #F5D10D; color: #0e1116; }
        .badge-day { background:#1f3a26; color:#52d27a; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:700; }
        .breadcrumb-mw { color:#6c7280; margin:20px 0 0; }
        .breadcrumb-mw a { color:#F5D10D; text-decoration:none; }
    </style>
</head>
<body>
    <div class="navbar-mw d-flex justify-content-between align-items-center">
        <a class="logo" href="/">💪 MUSCLEHELPER</a>
        <div>
            <a href="/">Início</a>
            <a href="/exercicio/index">Exercícios</a>
            <a href="/treino/index">Treino</a>
            <span style="color:#F5D10D; margin-left:24px; font-weight:600;">@Context.Session.GetString("UserName")</span>
            <a href="/autenticacao/sair" style="margin-left:12px;">Sair</a>
        </div>
    </div>

    @await Html.PartialAsync("_Toast")
    <div class="container my-4">
        <div class="breadcrumb-mw">
            <a href="/treino/index">Meus Treinos</a> &raquo;
            <a href="/treino/detalhes/@Model.WorkoutPlanId">@Model.WorkoutPlan?.Name</a> &raquo;
            <span style="color:#fff;">@Model.Name</span>
        </div>

        <div class="page-title mt-3"><span>@Model.Name</span></div>
        <span class="badge-day">@Model.DayOfWeek</span>

        <div class="section-title">Exercícios (@(Model.ExerciseItems?.Count ?? 0))</div>

        @if (Model.ExerciseItems == null || !Model.ExerciseItems.Any())
        {
            <p class="text-muted">Nenhum exercício nesta sessão. Adicione abaixo.</p>
        }
        else
        {
            var items = Model.ExerciseItems.OrderBy(e => e.Order).ToList();
            for (int i = 0; i < items.Count; i++)
            {
                var item = items[i];
                <div class="ex-row">
                    <div>
                        <span class="ex-meta me-2">@(i + 1).</span>
                        <span class="ex-name">@item.Exercise?.Name</span>
                        <span class="ex-meta ms-2">— @item.Exercise?.MuscleGroup?.Name</span>
                        <div class="mt-2">
                            <span class="pill pill-sets">@item.Sets séries × @item.Reps reps</span>
                            @if (item.SuggestedLoad > 0)
                            {
                                <span class="pill pill-load ms-1">@item.SuggestedLoad kg</span>
                            }
                        </div>
                    </div>
                    <a href="/sessaotreino/removerexercicio/@item.Id" class="btn btn-sm btn-danger"
                       onclick="return confirm('Remover @item.Exercise?.Name?')">Remover</a>
                </div>
            }
        }

        <div class="add-panel mt-4">
            <h5>+ Adicionar Exercício</h5>
            <form action="/sessaotreino/adicionarexercicio" method="POST">
                @Html.AntiForgeryToken()
                <input type="hidden" name="WorkoutSessionId" value="@Model.Id" />
                <div class="row g-3">
                    <div class="col-md-5">
                        <label>Exercício</label>
                        <select class="form-select" name="ExerciseId" required>
                            <option value="">Selecione...</option>
                            @foreach (var group in grouped)
                            {
                                <optgroup label="@group.Key">
                                    @foreach (var ex in group)
                                    {
                                        <option value="@ex.Id">@ex.Name</option>
                                    }
                                </optgroup>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label>Séries</label>
                        <input class="form-control" type="number" name="Sets" value="3" min="1" max="20" required />
                    </div>
                    <div class="col-md-2">
                        <label>Repetições</label>
                        <input class="form-control" type="number" name="Reps" value="12" min="1" max="100" required />
                    </div>
                    <div class="col-md-2">
                        <label>Carga (kg)</label>
                        <input class="form-control" type="number" name="SuggestedLoad" value="0" min="0" step="0.5" />
                    </div>
                    <div class="col-md-1 d-flex align-items-end">
                        <button type="submit" class="btn btn-mw w-100">+</button>
                    </div>
                </div>
            </form>
        </div>

        <a href="/treino/detalhes/@Model.WorkoutPlanId" class="btn btn-outline-mw mt-4">&laquo; Voltar ao Plano</a>
    </div>
</body>
</html>
