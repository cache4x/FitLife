<html>
<head>
    <title>Entrar - MuscleHelper</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
        body { background-color: #0e1116; color: #f1f1f1; font-family: 'Inter', -apple-system, sans-serif; }
        .navbar-mw { background-color: #181b21; border-bottom: 2px solid #F5D10D; padding: 18px 32px; }
        .logo { color: #F5D10D; font-weight: 900; font-size: 24px; letter-spacing: 2px; text-decoration: none; }
        .auth-card { background-color: #1c2027; border: 1px solid #2a2f38; border-radius: 12px; padding: 40px; max-width: 440px; margin: 60px auto; }
        h1 { font-weight: 800; } h1 span { color: #F5D10D; }
        label { color: #F5D10D; font-weight: 700; text-transform: uppercase; font-size: 12px; letter-spacing: 1px; }
        .form-control { background-color: #0e1116; color: #fff; border: 1px solid #2a2f38; border-radius: 8px; }
        .form-control:focus { background-color: #0e1116; color: #fff; border-color: #F5D10D; box-shadow: 0 0 0 .15rem rgba(245,209,13,.25); }
        .btn-mw { background-color: #F5D10D; color: #0e1116; font-weight: 700; border: none; width: 100%; padding: 10px; }
        .btn-mw:hover { background-color: #ffe14a; color: #0e1116; }
        .link-mw { color: #F5D10D; }
    </style>
</head>
<body>
    <div class="navbar-mw d-flex justify-content-between align-items-center">
        <a class="logo" href="/">💪 MUSCLEHELPER</a>
    </div>

    <div class="container">
        <div class="auth-card">
            <h1>Bem-vindo de <span>volta</span></h1>
            <p class="text-muted mb-4">Entre com sua conta para continuar</p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <form action="/autenticacao/entrar" method="POST">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label>E-mail</label>
                    <input class="form-control mt-1" type="email" name="email" placeholder="seu@email.com" required />
                </div>
                <div class="mb-4">
                    <label>Senha</label>
                    <input class="form-control mt-1" type="password" name="password" placeholder="••••••••" required />
                </div>
                <button type="submit" class="btn btn-mw">Entrar</button>
            </form>

            <p class="text-center mt-4 text-muted">
                Não tem conta? <a class="link-mw" href="/autenticacao/registrar">Cadastre-se</a>
            </p>
        </div>
    </div>
</body>
</html>
