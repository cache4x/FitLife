@{
    var muscles = (List<GrupoMuscular>)ViewBag.MuscleGroups;
}

<html>
<head>
    <title>Novo Exercício - MuscleHelper</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
        body {
            background-color: #0e1116;
            color: #f1f1f1;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }
        .navbar-mw {
            background-color: #181b21;
            border-bottom: 2px solid #F5D10D;
            padding: 18px 32px;
        }
        .logo {
            color: #F5D10D;
            font-weight: 900;
            font-size: 24px;
            letter-spacing: 2px;
            text-decoration: none;
        }
        .navbar-mw a {
            color: #ddd;
            text-decoration: none;
            margin-left: 24px;
            font-weight: 600;
        }
        .navbar-mw a:hover { color: #F5D10D; }
        .form-card {
            background-color: #1c2027;
            border: 1px solid #2a2f38;
            border-radius: 12px;
            padding: 32px;
            margin-top: 30px;
        }
        h1 { font-weight: 800; }
        h1 span { color: #F5D10D; }
        label {
            color: #F5D10D;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: 1px;
            margin-bottom: 4px;
        }
        .form-control, .form-select {
            background-color: #0e1116;
            color: #fff;
            border: 1px solid #2a2f38;
            border-radius: 8px;
        }
        .form-control:focus, .form-select:focus {
            background-color: #0e1116;
            color: #fff;
            border-color: #F5D10D;
            box-shadow: 0 0 0 .15rem rgba(245, 209, 13, .25);
        }
        .btn-mw {
            background-color: #F5D10D;
            color: #0e1116;
            font-weight: 700;
            border: none;
        }
        .btn-mw:hover { background-color: #ffe14a; color: #0e1116; }
        .btn-outline-mw {
            background: transparent;
            color: #F5D10D;
            border: 1px solid #F5D10D;
            font-weight: 700;
        }
        .btn-outline-mw:hover { background-color: #F5D10D; color: #0e1116; }
    </style>
</head>
<body>

    <div class="navbar-mw d-flex justify-content-between align-items-center">
        <a class="logo" href="/">💪 MUSCLEHELPER</a>
        <div>
            <a href="/">Início</a>
            <a href="/exercicio/index">Exercícios</a>
            <a href="/exercicio/criar">Adicionar</a>
            @if (Context.Session.GetString("UserId") != null)
            {
                <span style="color:#F5D10D; margin-left:24px; font-weight:600;">@Context.Session.GetString("UserName")</span>
                <a href="/autenticacao/sair" style="margin-left:12px;">Sair</a>
            }
        </div>
    </div>

    <div class="container">
        <div class="form-card">
            <h1>Adicionar <span>Exercício</span></h1>
            <p class="text-muted">Cadastre um novo exercício na biblioteca</p>

            <form action="/exercicio/criar" method="POST">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-md-8">
                        <label>Nome do Exercício</label>
                        <input class="form-control" name="Name" placeholder="Ex.: Supino Reto" required/>
                    </div>

                    <div class="col-md-4">
                        <label>Grupo Muscular</label>
                        <select class="form-select" name="MuscleGroupId" required>
                            <option value="">Selecione...</option>
                            @foreach (GrupoMuscular m in muscles)
                            {
                                <option value="@m.Id">@m.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label>Dificuldade</label>
                        <select class="form-select" name="Difficulty">
                            <option value="Iniciante">Iniciante</option>
                            <option value="Intermediário">Intermediário</option>
                            <option value="Avançado">Avançado</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label>Equipamento</label>
                        <select class="form-select" name="Equipment">
                            <option value="Peso Corporal">Peso Corporal</option>
                            <option value="Halteres">Halteres</option>
                            <option value="Barra">Barra</option>
                            <option value="Cabos">Cabos</option>
                            <option value="Máquina">Máquina</option>
                            <option value="Kettlebell">Kettlebell</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <label>Descrição</label>
                        <textarea class="form-control" name="Description" rows="3" placeholder="Resumo curto do movimento"></textarea>
                    </div>

                    <div class="col-12">
                        <label>Passos (um por linha)</label>
                        <textarea class="form-control" name="Steps" rows="6" placeholder="1. Deite no banco com os pés apoiados&#10;2. Segure a barra com pegada média&#10;3. Desça a barra até o peito&#10;4. Empurre de volta à posição inicial"></textarea>
                    </div>

                    <div class="col-12">
                        <label>URL da Imagem (opcional)</label>
                        <input class="form-control" name="ImageUrl" placeholder="https://..."/>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-mw">Salvar Exercício</button>
                    <a href="/exercicio/index" class="btn btn-outline-mw">Cancelar</a>
                </div>

            </form>
        </div>
    </div>

</body>
</html>
