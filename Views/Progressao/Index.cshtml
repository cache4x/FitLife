@model List<ProgressaoCarga>
@{
    var exercise = (Exercicio)ViewBag.Exercise;
    var userName = Context.Session.GetString("UserName");
    var chartLabels = string.Join(",", Model.Select(r => $"\"{r.Date.ToString("dd/MM")}\""));
    var chartLoads  = string.Join(",", Model.Select(r => r.Load.ToString(System.Globalization.CultureInfo.InvariantCulture)));
    var chartVol    = string.Join(",", Model.Select(r => (r.Sets * r.Reps * r.Load).ToString(System.Globalization.CultureInfo.InvariantCulture)));
    var maxLoad = Model.Any() ? Model.Max(r => r.Load) : 0;
    var lastLoad = Model.Any() ? Model.Last().Load : 0;
    var firstLoad = Model.Any() ? Model.First().Load : 0;
    decimal diff = lastLoad - firstLoad;
}
<html>
<head>
    <title>Progressão — @exercise.Name - MuscleHelper</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <style>
        body { background-color: #0e1116; color: #f1f1f1; font-family: 'Inter', -apple-system, sans-serif; }
        .navbar-mw { background-color: #181b21; border-bottom: 2px solid #F5D10D; padding: 18px 32px; }
        .logo { color: #F5D10D; font-weight: 900; font-size: 24px; letter-spacing: 2px; text-decoration: none; }
        .navbar-mw a { color: #ddd; text-decoration: none; margin-left: 24px; font-weight: 600; }
        .navbar-mw a:hover { color: #F5D10D; }
        .page-title { font-weight: 800; font-size: 28px; margin: 28px 0 4px; }
        .page-title span { color: #F5D10D; }
        .section-title { color: #F5D10D; text-transform: uppercase; letter-spacing: 3px; font-weight: 700; border-left: 4px solid #F5D10D; padding-left: 12px; margin: 28px 0 16px; font-size: 14px; }
        .stat-card { background-color: #1c2027; border: 1px solid #2a2f38; border-radius: 12px; padding: 20px 24px; text-align: center; }
        .stat-val { font-size: 32px; font-weight: 800; color: #F5D10D; }
        .stat-label { color: #9aa0a6; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; margin-top: 4px; }
        .stat-diff { font-size: 14px; font-weight: 700; }
        .stat-diff.pos { color: #52d27a; }
        .stat-diff.neg { color: #f56565; }
        .chart-card { background-color: #1c2027; border: 1px solid #2a2f38; border-radius: 12px; padding: 24px; margin-bottom: 24px; }
        .record-row { background-color: #1c2027; border: 1px solid #2a2f38; border-radius: 10px; padding: 14px 20px; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center; }
        .record-row:hover { border-color: #F5D10D; }
        .rec-date { color: #9aa0a6; font-size: 13px; min-width: 80px; }
        .rec-load { font-size: 20px; font-weight: 800; color: #F5D10D; }
        .rec-sets { color: #7cb1ff; font-size: 13px; }
        .rec-notes { color: #6c7280; font-size: 12px; font-style: italic; margin-top: 2px; }
        .pill { display:inline-block; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; }
        .pill-muscle { background:#2a2f38; color:#fff; }
        .btn-mw { background-color: #F5D10D; color: #0e1116; font-weight: 700; border: none; }
        .btn-mw:hover { background-color: #ffe14a; color: #0e1116; }
        .btn-outline-mw { background: transparent; color: #F5D10D; border: 1px solid #F5D10D; font-weight: 700; }
        .btn-outline-mw:hover { background-color: #F5D10D; color: #0e1116; }
        .empty-state { text-align: center; padding: 60px 20px; color: #6c7280; }
        .empty-state h3 { color: #F5D10D; }
        .breadcrumb-mw { color: #6c7280; margin: 20px 0 0; }
        .breadcrumb-mw a { color: #F5D10D; text-decoration: none; }
    </style>
</head>
<body>
    <div class="navbar-mw d-flex justify-content-between align-items-center">
        <a class="logo" href="/">💪 MUSCLEHELPER</a>
        <div>
            <a href="/">Início</a>
            <a href="/exercicio/index">Exercícios</a>
            <a href="/treino/index">Treino</a>
            <a href="/dieta/index">Dieta</a>
            <a href="/agenda/index">Agenda</a>
            <span style="color:#F5D10D; margin-left:24px; font-weight:600;">@userName</span>
            <a href="/autenticacao/sair" style="margin-left:12px;">Sair</a>
        </div>
    </div>

    @await Html.PartialAsync("_Toast")
    <div class="container my-4">
        <div class="breadcrumb-mw">
            <a href="/exercicio/index">Exercícios</a> &raquo;
            <a href="/exercicio/detalhes/@exercise.Id">@exercise.Name</a> &raquo;
            <span style="color:#fff;">Progressão de Carga</span>
        </div>

        <div class="d-flex justify-content-between align-items-start mt-3">
            <div>
                <div class="page-title"><span>@exercise.Name</span></div>
                <span class="pill pill-muscle">@exercise.MuscleGroup?.Name</span>
                <span class="text-muted ms-2" style="font-size:13px;">@Model.Count registro(s)</span>
            </div>
            <a href="/progressao/adicionar?exerciseId=@exercise.Id" class="btn btn-mw">+ Registrar Carga</a>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <h3>Nenhum registro ainda</h3>
                <p>Registre sua primeira carga para começar a acompanhar sua evolução.</p>
                <a href="/progressao/adicionar?exerciseId=@exercise.Id" class="btn btn-mw">+ Registrar Agora</a>
            </div>
        }
        else
        {
            <div class="row g-3 my-2">
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="stat-val">@maxLoad kg</div>
                        <div class="stat-label">Carga Máxima</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="stat-val">@lastLoad kg</div>
                        <div class="stat-label">Último Registro</div>
                        @if (Model.Count > 1)
                        {
                            <div class="stat-diff @(diff >= 0 ? "pos" : "neg")">
                                @(diff >= 0 ? "+" : "")@diff kg vs início
                            </div>
                        }
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="stat-val">@Model.Count</div>
                        <div class="stat-label">Treinos Registrados</div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="stat-val">@Model.Last().Sets×@Model.Last().Reps</div>
                        <div class="stat-label">Último Vol. (séries×reps)</div>
                    </div>
                </div>
            </div>

            <div class="chart-card">
                <div class="section-title" style="margin-top:0;">Evolução da Carga (kg)</div>
                <canvas id="chartLoad" height="90"></canvas>
            </div>

            <div class="section-title">Histórico</div>

            @foreach (var rec in Model.OrderByDescending(r => r.Date))
            {
                <div class="record-row">
                    <div>
                        <div class="rec-date">@rec.Date.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                        <div class="d-flex align-items-baseline gap-2 mt-1">
                            <span class="rec-load">@rec.Load kg</span>
                            <span class="rec-sets">@rec.Sets séries × @rec.Reps reps</span>
                        </div>
                        @if (!string.IsNullOrEmpty(rec.Notes))
                        {
                            <div class="rec-notes">@rec.Notes</div>
                        }
                    </div>
                    <a href="/progressao/excluir/@rec.Id" class="btn btn-sm btn-danger"
                       onclick="return confirm('Excluir este registro?')">Excluir</a>
                </div>
            }
        }

        <a href="/exercicio/detalhes/@exercise.Id" class="btn btn-outline-mw mt-3">&laquo; Voltar ao Exercício</a>
    </div>

    @if (Model.Any())
    {
        <script>
            new Chart(document.getElementById('chartLoad'), {
                type: 'line',
                data: {
                    labels: [@Html.Raw(chartLabels)],
                    datasets: [{
                        label: 'Carga (kg)',
                        data: [@Html.Raw(chartLoads)],
                        borderColor: '#F5D10D',
                        backgroundColor: 'rgba(245,209,13,0.12)',
                        borderWidth: 2,
                        pointBackgroundColor: '#F5D10D',
                        pointRadius: 5,
                        tension: 0.3,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { labels: { color: '#f1f1f1' } } },
                    scales: {
                        x: { ticks: { color: '#9aa0a6' }, grid: { color: '#2a2f38' } },
                        y: { ticks: { color: '#9aa0a6' }, grid: { color: '#2a2f38' }, beginAtZero: false }
                    }
                }
            });
        </script>
    }
</body>
</html>
