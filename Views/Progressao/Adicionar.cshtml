@{
    var exercise = (Exercicio)ViewBag.Exercise;
    var userName = Context.Session.GetString("UserName");
}
<html>
<head>
    <title>Registrar Carga - MuscleHelper</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
        body { background-color: #0e1116; color: #f1f1f1; font-family: 'Inter', -apple-system, sans-serif; }
        .navbar-mw { background-color: #181b21; border-bottom: 2px solid #F5D10D; padding: 18px 32px; }
        .logo { color: #F5D10D; font-weight: 900; font-size: 24px; letter-spacing: 2px; text-decoration: none; }
        .navbar-mw a { color: #ddd; text-decoration: none; margin-left: 24px; font-weight: 600; }
        .navbar-mw a:hover { color: #F5D10D; }
        .page-title { font-weight: 800; font-size: 32px; margin: 30px 0 4px; }
        .page-title span { color: #F5D10D; }
        .form-card { background-color: #1c2027; border: 1px solid #2a2f38; border-radius: 12px; padding: 32px; max-width: 520px; margin-top: 24px; }
        .form-label { color: #aaa; font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; }
        .form-control, .form-select { background-color: #0e1116; border: 1px solid #2a2f38; color: #f1f1f1; }
        .form-control:focus { background-color: #0e1116; border-color: #F5D10D; color: #f1f1f1; box-shadow: 0 0 0 2px rgba(245,209,13,.2); }
        .btn-mw { background-color: #F5D10D; color: #0e1116; font-weight: 700; border: none; }
        .btn-mw:hover { background-color: #ffe14a; color: #0e1116; }
        .btn-outline-mw { background: transparent; color: #F5D10D; border: 1px solid #F5D10D; font-weight: 700; }
        .btn-outline-mw:hover { background-color: #F5D10D; color: #0e1116; }
        .breadcrumb-mw { color: #6c7280; margin: 20px 0 0; }
        .breadcrumb-mw a { color: #F5D10D; text-decoration: none; }
        .ex-chip { background:#1c2027; border:1px solid #2a2f38; border-radius:8px; padding:12px 16px; margin-bottom:20px; }
        .ex-chip .name { font-weight:700; font-size:18px; }
        .ex-chip .meta { color:#9aa0a6; font-size:13px; }
    </style>
</head>
<body>
    <div class="navbar-mw d-flex justify-content-between align-items-center">
        <a class="logo" href="/">💪 MUSCLEHELPER</a>
        <div>
            <a href="/">Início</a>
            <a href="/exercicio/index">Exercícios</a>
            <a href="/treino/index">Treino</a>
            <a href="/dieta/index">Dieta</a>
            <a href="/agenda/index">Agenda</a>
            <span style="color:#F5D10D; margin-left:24px; font-weight:600;">@userName</span>
            <a href="/autenticacao/sair" style="margin-left:12px;">Sair</a>
        </div>
    </div>

    <div class="container my-4">
        <div class="breadcrumb-mw">
            <a href="/exercicio/index">Exercícios</a> &raquo;
            <a href="/exercicio/detalhes/@exercise.Id">@exercise.Name</a> &raquo;
            <a href="/progressao/index?exerciseId=@exercise.Id">Progressão</a> &raquo;
            <span style="color:#fff;">Registrar</span>
        </div>

        <div class="page-title mt-3">Registrar <span>Carga</span></div>

        <div class="form-card">
            <div class="ex-chip">
                <div class="name">@exercise.Name</div>
                <div class="meta">@exercise.MuscleGroup?.Name &bull; @exercise.Equipment</div>
            </div>

            <form method="post" action="/progressao/adicionar">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ExerciseId" value="@exercise.Id" />
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label">Séries</label>
                        <input type="number" name="Sets" class="form-control" value="3" min="1" max="20" required />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Repetições</label>
                        <input type="number" name="Reps" class="form-control" value="12" min="1" max="200" required />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Carga (kg)</label>
                    <input type="number" name="Load" class="form-control" value="0" min="0" step="0.5" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Data</label>
                    <input type="datetime-local" name="Date" class="form-control"
                           value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                </div>
                <div class="mb-4">
                    <label class="form-label">Observações (opcional)</label>
                    <textarea name="Notes" class="form-control" rows="2" placeholder="Ex: Senti dificuldade nos últimos reps"></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-mw px-4">Salvar</button>
                    <a href="/progressao/index?exerciseId=@exercise.Id" class="btn btn-outline-mw px-4">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
