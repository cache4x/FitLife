<html>
<head>
    <title>Novo Plano de Treino - MuscleHelper</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
        body { background-color: #0e1116; color: #f1f1f1; font-family: 'Inter', -apple-system, sans-serif; }
        .navbar-mw { background-color: #181b21; border-bottom: 2px solid #F5D10D; padding: 18px 32px; }
        .logo { color: #F5D10D; font-weight: 900; font-size: 24px; letter-spacing: 2px; text-decoration: none; }
        .navbar-mw a { color: #ddd; text-decoration: none; margin-left: 24px; font-weight: 600; }
        .navbar-mw a:hover { color: #F5D10D; }
        .form-card { background-color: #1c2027; border: 1px solid #2a2f38; border-radius: 12px; padding: 32px; margin-top: 30px; max-width: 600px; }
        h1 { font-weight: 800; } h1 span { color: #F5D10D; }
        label { color: #F5D10D; font-weight: 700; text-transform: uppercase; font-size: 12px; letter-spacing: 1px; margin-bottom: 4px; }
        .form-control, .form-select { background-color: #0e1116; color: #fff; border: 1px solid #2a2f38; border-radius: 8px; }
        .form-control:focus, .form-select:focus { background-color: #0e1116; color: #fff; border-color: #F5D10D; box-shadow: 0 0 0 .15rem rgba(245,209,13,.25); }
        .btn-mw { background-color: #F5D10D; color: #0e1116; font-weight: 700; border: none; }
        .btn-mw:hover { background-color: #ffe14a; color: #0e1116; }
        .btn-outline-mw { background: transparent; color: #F5D10D; border: 1px solid #F5D10D; font-weight: 700; }
        .btn-outline-mw:hover { background-color: #F5D10D; color: #0e1116; }
    </style>
</head>
<body>
    <div class="navbar-mw d-flex justify-content-between align-items-center">
        <a class="logo" href="/">💪 MUSCLEHELPER</a>
        <div>
            <a href="/">Início</a>
            <a href="/exercicio/index">Exercícios</a>
            <a href="/treino/index">Treino</a>
            <span style="color:#F5D10D; margin-left:24px; font-weight:600;">@Context.Session.GetString("UserName")</span>
            <a href="/autenticacao/sair" style="margin-left:12px;">Sair</a>
        </div>
    </div>

    <div class="container">
        <div class="form-card">
            <h1>Novo <span>Plano de Treino</span></h1>
            <p class="text-muted">Defina o nome e objetivo do seu plano</p>

            <form action="/treino/criar" method="POST">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label>Nome do Plano</label>
                    <input class="form-control mt-1" name="Name" placeholder="Ex.: Treino ABC, Força 3x" required />
                </div>
                <div class="mb-4">
                    <label>Objetivo</label>
                    <select class="form-select mt-1" name="Goal">
                        <option value="Hipertrofia">Hipertrofia</option>
                        <option value="Força">Força</option>
                        <option value="Resistência">Resistência</option>
                        <option value="Emagrecimento">Emagrecimento</option>
                    </select>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-mw">Criar Plano</button>
                    <a href="/treino/index" class="btn btn-outline-mw">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
