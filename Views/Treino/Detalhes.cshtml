@model PlanoTreino
<html>
<head>
    <title>@Model.Name - MuscleHelper</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
        body { background-color: #0e1116; color: #f1f1f1; font-family: 'Inter', -apple-system, sans-serif; }
        .navbar-mw { background-color: #181b21; border-bottom: 2px solid #F5D10D; padding: 18px 32px; }
        .logo { color: #F5D10D; font-weight: 900; font-size: 24px; letter-spacing: 2px; text-decoration: none; }
        .navbar-mw a { color: #ddd; text-decoration: none; margin-left: 24px; font-weight: 600; }
        .navbar-mw a:hover { color: #F5D10D; }
        .page-title { font-weight: 800; font-size: 32px; margin: 30px 0 4px; }
        .page-title span { color: #F5D10D; }
        .section-title { color: #F5D10D; text-transform: uppercase; letter-spacing: 3px; font-weight: 700; border-left: 4px solid #F5D10D; padding-left: 12px; margin: 28px 0 16px; font-size: 14px; }
        .session-card { background-color: #1c2027; border: 1px solid #2a2f38; border-radius: 12px; padding: 20px 24px; margin-bottom: 14px; display: flex; justify-content: space-between; align-items: center; transition: all .2s; }
        .session-card:hover { border-color: #F5D10D; }
        .session-name { font-weight: 700; font-size: 17px; }
        .badge-day { background:#1f3a26; color:#52d27a; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 700; }
        .badge-goal { background:#3a361f; color:#f5d10d; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 700; text-transform: uppercase; }
        .btn-mw { background-color: #F5D10D; color: #0e1116; font-weight: 700; border: none; }
        .btn-mw:hover { background-color: #ffe14a; color: #0e1116; }
        .btn-outline-mw { background: transparent; color: #F5D10D; border: 1px solid #F5D10D; font-weight: 700; }
        .btn-outline-mw:hover { background-color: #F5D10D; color: #0e1116; }
        .empty-state { text-align: center; padding: 50px 20px; color: #6c7280; }
        .breadcrumb-mw { color: #6c7280; margin: 20px 0 0; }
        .breadcrumb-mw a { color: #F5D10D; text-decoration: none; }
    </style>
</head>
<body>
    <div class="navbar-mw d-flex justify-content-between align-items-center">
        <a class="logo" href="/">💪 MUSCLEHELPER</a>
        <div>
            <a href="/">Início</a>
            <a href="/exercicio/index">Exercícios</a>
            <a href="/treino/index">Treino</a>
            <span style="color:#F5D10D; margin-left:24px; font-weight:600;">@Context.Session.GetString("UserName")</span>
            <a href="/autenticacao/sair" style="margin-left:12px;">Sair</a>
        </div>
    </div>

    @await Html.PartialAsync("_Toast")
    <div class="container my-4">
        <div class="breadcrumb-mw">
            <a href="/treino/index">Meus Treinos</a> &raquo; <span style="color:#fff;">@Model.Name</span>
        </div>

        <div class="d-flex justify-content-between align-items-start mt-3">
            <div>
                <div class="page-title"><span>@Model.Name</span></div>
                <span class="badge-goal">@Model.Goal</span>
                <span class="text-muted ms-3" style="font-size:13px;">@(Model.Sessions?.Count ?? 0) sessão(ões)</span>
            </div>
            <a href="/sessaotreino/criar?planId=@Model.Id" class="btn btn-mw">+ Nova Sessão</a>
        </div>

        <div class="section-title">Sessões de Treino</div>

        @if (Model.Sessions == null || !Model.Sessions.Any())
        {
            <div class="empty-state">
                <p>Nenhuma sessão cadastrada.</p>
                <a href="/sessaotreino/criar?planId=@Model.Id" class="btn btn-mw">+ Adicionar Sessão</a>
            </div>
        }
        else
        {
            foreach (var session in Model.Sessions)
            {
                <div class="session-card">
                    <div>
                        <div class="session-name">@session.Name</div>
                        <span class="badge-day mt-2 d-inline-block">@session.DayOfWeek</span>
                    </div>
                    <div class="d-flex gap-2">
                        <a href="/sessaotreino/detalhes/@session.Id" class="btn btn-sm btn-outline-mw">Ver Exercícios</a>
                        <a href="/sessaotreino/excluirsessao/@session.Id" class="btn btn-sm btn-danger"
                           onclick="return confirm('Excluir sessão @session.Name?')">Excluir</a>
                    </div>
                </div>
            }
        }

        <a href="/treino/index" class="btn btn-outline-mw mt-3">&laquo; Voltar</a>
    </div>
</body>
</html>
