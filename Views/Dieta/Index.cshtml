@model List<PlanoAlimentar>
@{
    var userName = Context.Session.GetString("UserName");
}
<html>
<head>
    <title>Minha Dieta - MuscleHelper</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
        body { background-color: #0e1116; color: #f1f1f1; font-family: 'Inter', -apple-system, sans-serif; }
        .navbar-mw { background-color: #181b21; border-bottom: 2px solid #F5D10D; padding: 18px 32px; }
        .logo { color: #F5D10D; font-weight: 900; font-size: 24px; letter-spacing: 2px; text-decoration: none; }
        .navbar-mw a { color: #ddd; text-decoration: none; margin-left: 24px; font-weight: 600; }
        .navbar-mw a:hover { color: #F5D10D; }
        .page-title { font-weight: 800; font-size: 32px; margin: 30px 0 8px; }
        .page-title span { color: #F5D10D; }
        .plan-card { background-color: #1c2027; border: 1px solid #2a2f38; border-radius: 12px; padding: 24px; margin-bottom: 20px; transition: all .2s; }
        .plan-card:hover { border-color: #F5D10D; }
        .plan-name { font-weight: 700; font-size: 20px; }
        .badge-cal { background:#1f3a3a; color:#4dd9d9; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 700; }
        .btn-mw { background-color: #F5D10D; color: #0e1116; font-weight: 700; border: none; }
        .btn-mw:hover { background-color: #ffe14a; color: #0e1116; }
        .btn-outline-mw { background: transparent; color: #F5D10D; border: 1px solid #F5D10D; font-weight: 700; }
        .btn-outline-mw:hover { background-color: #F5D10D; color: #0e1116; }
        .empty-state { text-align: center; padding: 80px 20px; color: #6c7280; }
        .empty-state h3 { color: #F5D10D; }
    </style>
</head>
<body>
    <div class="navbar-mw d-flex justify-content-between align-items-center">
        <a class="logo" href="/">💪 MUSCLEHELPER</a>
        <div>
            <a href="/">Início</a>
            <a href="/exercicio/index">Exercícios</a>
            <a href="/treino/index">Treino</a>
            <a href="/dieta/index">Dieta</a>
            <span style="color:#F5D10D; margin-left:24px; font-weight:600;">@userName</span>
            <a href="/autenticacao/sair" style="margin-left:12px;">Sair</a>
        </div>
    </div>

    @await Html.PartialAsync("_Toast")
    <div class="container my-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <div class="page-title">Meus <span>Planos Alimentares</span></div>
                <p class="text-muted">@Model.Count plano(s) cadastrado(s)</p>
            </div>
            <a href="/dieta/criar" class="btn btn-mw">+ Novo Plano</a>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <h3>Nenhum plano criado</h3>
                <p>Crie seu primeiro plano alimentar para começar.</p>
                <a href="/dieta/criar" class="btn btn-mw">+ Criar Plano</a>
            </div>
        }
        else
        {
            foreach (var plan in Model)
            {
                <div class="plan-card">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="plan-name">@plan.Name</div>
                            <div class="mt-2">
                                <span class="badge-cal">@plan.CalorieGoal kcal/dia</span>
                                <span class="text-muted ms-3" style="font-size:13px;">@(plan.Meals?.Count ?? 0) refeição(ões)</span>
                            </div>
                            <div class="text-muted mt-1" style="font-size:12px;">
                                Início: @plan.StartDate.ToString("dd/MM/yyyy")
                                @if (plan.EndDate.HasValue)
                                {
                                    <span> &bull; Fim: @plan.EndDate.Value.ToString("dd/MM/yyyy")</span>
                                }
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <a href="/dieta/detalhes/@plan.Id" class="btn btn-sm btn-outline-mw">Ver Refeições</a>
                            <a href="/dieta/excluir/@plan.Id" class="btn btn-sm btn-danger"
                               onclick="return confirm('Excluir o plano @plan.Name e todas as suas refeições?')">Excluir</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</body>
</html>
