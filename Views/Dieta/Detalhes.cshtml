@model PlanoAlimentar
<html>
<head>
    <title>@Model.Name - MuscleHelper</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
        body { background-color: #0e1116; color: #f1f1f1; font-family: 'Inter', -apple-system, sans-serif; }
        .navbar-mw { background-color: #181b21; border-bottom: 2px solid #F5D10D; padding: 18px 32px; }
        .logo { color: #F5D10D; font-weight: 900; font-size: 24px; letter-spacing: 2px; text-decoration: none; }
        .navbar-mw a { color: #ddd; text-decoration: none; margin-left: 24px; font-weight: 600; }
        .navbar-mw a:hover { color: #F5D10D; }
        .page-title { font-weight: 800; font-size: 28px; margin: 28px 0 4px; }
        .page-title span { color: #F5D10D; }
        .section-title { color: #F5D10D; text-transform: uppercase; letter-spacing: 3px; font-weight: 700; border-left: 4px solid #F5D10D; padding-left: 12px; margin: 28px 0 16px; font-size: 14px; }
        .meal-card { background-color: #1c2027; border: 1px solid #2a2f38; border-radius: 12px; padding: 20px 24px; margin-bottom: 20px; }
        .meal-card:hover { border-color: #F5D10D; }
        .meal-name { font-weight: 700; font-size: 18px; }
        .badge-cal { background:#1f3a3a; color:#4dd9d9; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:700; }
        .badge-time { background:#3a361f; color:#f5d10d; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:700; }
        .item-row { display:flex; justify-content:space-between; align-items:center; padding:8px 0; border-bottom:1px solid #2a2f38; }
        .item-row:last-child { border-bottom: none; }
        .item-food { font-weight: 600; }
        .item-meta { color:#9aa0a6; font-size:13px; }
        .add-panel { background-color: #161b22; border: 1px solid #2a2f38; border-radius: 10px; padding: 18px; margin-top: 12px; }
        .add-panel h6 { color: #F5D10D; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; font-size: 12px; margin-bottom: 12px; }
        label { color: #aaa; font-weight: 600; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
        .form-control, .form-select { background-color: #0e1116; color: #fff; border: 1px solid #2a2f38; border-radius: 8px; }
        .form-control:focus, .form-select:focus { background-color: #0e1116; color: #fff; border-color: #F5D10D; box-shadow: 0 0 0 .15rem rgba(245,209,13,.25); }
        .btn-mw { background-color: #F5D10D; color: #0e1116; font-weight: 700; border: none; }
        .btn-mw:hover { background-color: #ffe14a; color: #0e1116; }
        .btn-outline-mw { background: transparent; color: #F5D10D; border: 1px solid #F5D10D; font-weight: 700; }
        .btn-outline-mw:hover { background-color: #F5D10D; color: #0e1116; }
        .new-meal-panel { background-color: #1c2027; border: 1px dashed #F5D10D; border-radius: 12px; padding: 24px; margin-top: 10px; }
        .new-meal-panel h5 { color: #F5D10D; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; font-size: 13px; margin-bottom: 16px; }
        .breadcrumb-mw { color:#6c7280; margin:20px 0 0; }
        .breadcrumb-mw a { color:#F5D10D; text-decoration:none; }
        .calorie-bar-bg { background:#2a2f38; border-radius:8px; height:10px; overflow:hidden; margin-top:6px; }
        .calorie-bar-fill { background:#F5D10D; height:100%; border-radius:8px; transition: width .4s; }
    </style>
</head>
<body>
    <div class="navbar-mw d-flex justify-content-between align-items-center">
        <a class="logo" href="/">💪 MUSCLEHELPER</a>
        <div>
            <a href="/">Início</a>
            <a href="/exercicio/index">Exercícios</a>
            <a href="/treino/index">Treino</a>
            <a href="/dieta/index">Dieta</a>
            <span style="color:#F5D10D; margin-left:24px; font-weight:600;">@Context.Session.GetString("UserName")</span>
            <a href="/autenticacao/sair" style="margin-left:12px;">Sair</a>
        </div>
    </div>

    @await Html.PartialAsync("_Toast")
    <div class="container my-4">
        <div class="breadcrumb-mw">
            <a href="/dieta/index">Minha Dieta</a> &raquo; <span style="color:#fff;">@Model.Name</span>
        </div>

        @{
            int totalConsumed = Model.Meals?.Sum(m => m.TotalCalories) ?? 0;
            int goal = Model.CalorieGoal > 0 ? Model.CalorieGoal : 1;
            int pct = Math.Min(100, (int)Math.Round((double)totalConsumed / goal * 100));
        }

        <div class="d-flex justify-content-between align-items-start mt-3">
            <div>
                <div class="page-title"><span>@Model.Name</span></div>
                <div class="mt-2">
                    <span class="badge-cal">Meta: @Model.CalorieGoal kcal/dia</span>
                    <span class="text-muted ms-3" style="font-size:13px;">
                        @totalConsumed kcal planejadas (@pct%)
                    </span>
                </div>
                <div class="calorie-bar-bg mt-2" style="width:280px;">
                    <div class="calorie-bar-fill" style="width:@pct%;"></div>
                </div>
                <div class="text-muted mt-2" style="font-size:12px;">
                    Início: @Model.StartDate.ToString("dd/MM/yyyy")
                    @if (Model.EndDate.HasValue)
                    {
                        <span> &bull; Fim: @Model.EndDate.Value.ToString("dd/MM/yyyy")</span>
                    }
                </div>
            </div>
        </div>

        <div class="section-title">Refeições (@(Model.Meals?.Count ?? 0))</div>

        @if (Model.Meals == null || !Model.Meals.Any())
        {
            <p class="text-muted">Nenhuma refeição cadastrada. Adicione abaixo.</p>
        }
        else
        {
            foreach (var meal in Model.Meals)
            {
                <div class="meal-card">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <span class="meal-name">@meal.Name</span>
                            @if (!string.IsNullOrEmpty(meal.SuggestedTime))
                            {
                                <span class="badge-time ms-2">@meal.SuggestedTime</span>
                            }
                            <span class="badge-cal ms-2">@meal.TotalCalories kcal</span>
                        </div>
                        <a href="/refeicao/excluirrefeicao/@meal.Id" class="btn btn-sm btn-danger"
                           onclick="return confirm('Excluir refeição @meal.Name?')">Excluir</a>
                    </div>

                    @if (meal.Items != null && meal.Items.Any())
                    {
                        <div class="mt-3">
                            @foreach (var item in meal.Items)
                            {
                                <div class="item-row">
                                    <div>
                                        <span class="item-food">@item.Food</span>
                                        <span class="item-meta ms-2">@item.Quantity @item.Unit</span>
                                    </div>
                                    <div class="d-flex align-items-center gap-3">
                                        <span class="badge-cal">@item.Calories kcal</span>
                                        <a href="/refeicao/removeritem/@item.Id" class="btn btn-sm btn-outline-danger btn-sm"
                                           onclick="return confirm('Remover @item.Food?')"
                                           style="font-size:11px; padding:2px 8px;">✕</a>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <div class="add-panel">
                        <h6>+ Adicionar Alimento</h6>
                        <form action="/refeicao/adicionaritem" method="POST">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="MealId" value="@meal.Id" />
                            <div class="row g-2">
                                <div class="col-md-4">
                                    <label>Alimento</label>
                                    <input class="form-control" type="text" name="Food" placeholder="Ex: Frango grelhado" required />
                                </div>
                                <div class="col-md-2">
                                    <label>Quantidade</label>
                                    <input class="form-control" type="number" name="Quantity" value="100" min="0.1" step="0.1" required />
                                </div>
                                <div class="col-md-2">
                                    <label>Unidade</label>
                                    <select class="form-select" name="Unit">
                                        <option value="g">g</option>
                                        <option value="ml">ml</option>
                                        <option value="un">un</option>
                                        <option value="colher">colher</option>
                                        <option value="xícara">xícara</option>
                                        <option value="porção">porção</option>
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <label>Calorias (kcal)</label>
                                    <input class="form-control" type="number" name="Calories" value="0" min="0" required />
                                </div>
                                <div class="col-md-2 d-flex align-items-end">
                                    <button type="submit" class="btn btn-mw w-100">Adicionar</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            }
        }

        <div class="new-meal-panel">
            <h5>+ Nova Refeição</h5>
            <form action="/refeicao/criar" method="POST">
                @Html.AntiForgeryToken()
                <input type="hidden" name="DietPlanId" value="@Model.Id" />
                <div class="row g-3">
                    <div class="col-md-5">
                        <label>Nome da Refeição</label>
                        <input class="form-control" type="text" name="Name" placeholder="Ex: Café da Manhã" required />
                    </div>
                    <div class="col-md-3">
                        <label>Horário Sugerido</label>
                        <input class="form-control" type="text" name="SuggestedTime" placeholder="Ex: 07:00" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-mw w-100">Criar</button>
                    </div>
                </div>
            </form>
        </div>

        <a href="/dieta/index" class="btn btn-outline-mw mt-4">&laquo; Voltar à Dieta</a>
    </div>
</body>
</html>
