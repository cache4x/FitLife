@{
    var sessions = (List<SessaoTreino>)ViewBag.Sessions;
    var meals    = (List<Refeicao>)ViewBag.Meals;
    var userName = Context.Session.GetString("UserName");
}
<html>
<head>
    <title>Novo Agendamento - MuscleHelper</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <style>
        body { background-color: #0e1116; color: #f1f1f1; font-family: 'Inter', -apple-system, sans-serif; }
        .navbar-mw { background-color: #181b21; border-bottom: 2px solid #F5D10D; padding: 18px 32px; }
        .logo { color: #F5D10D; font-weight: 900; font-size: 24px; letter-spacing: 2px; text-decoration: none; }
        .navbar-mw a { color: #ddd; text-decoration: none; margin-left: 24px; font-weight: 600; }
        .navbar-mw a:hover { color: #F5D10D; }
        .page-title { font-weight: 800; font-size: 32px; margin: 30px 0 4px; }
        .page-title span { color: #F5D10D; }
        .form-card { background-color: #1c2027; border: 1px solid #2a2f38; border-radius: 12px; padding: 32px; max-width: 580px; margin-top: 24px; }
        .form-label { color: #aaa; font-weight: 600; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; }
        .form-control, .form-select { background-color: #0e1116; border: 1px solid #2a2f38; color: #f1f1f1; }
        .form-control:focus, .form-select:focus { background-color: #0e1116; border-color: #F5D10D; color: #f1f1f1; box-shadow: 0 0 0 2px rgba(245,209,13,.2); }
        .btn-mw { background-color: #F5D10D; color: #0e1116; font-weight: 700; border: none; }
        .btn-mw:hover { background-color: #ffe14a; color: #0e1116; }
        .btn-outline-mw { background: transparent; color: #F5D10D; border: 1px solid #F5D10D; font-weight: 700; }
        .btn-outline-mw:hover { background-color: #F5D10D; color: #0e1116; }
        .breadcrumb-mw { color: #6c7280; margin: 20px 0 0; }
        .breadcrumb-mw a { color: #F5D10D; text-decoration: none; }
        #sessaoGroup, #refeicaoGroup { display: none; }
    </style>
</head>
<body>
    <div class="navbar-mw d-flex justify-content-between align-items-center">
        <a class="logo" href="/">💪 MUSCLEHELPER</a>
        <div>
            <a href="/">Início</a>
            <a href="/exercicio/index">Exercícios</a>
            <a href="/treino/index">Treino</a>
            <a href="/dieta/index">Dieta</a>
            <a href="/agenda/index">Agenda</a>
            <span style="color:#F5D10D; margin-left:24px; font-weight:600;">@userName</span>
            <a href="/autenticacao/sair" style="margin-left:12px;">Sair</a>
        </div>
    </div>

    <div class="container my-4">
        <div class="breadcrumb-mw">
            <a href="/agenda/index">Agenda</a> &raquo; <span style="color:#fff;">Novo Agendamento</span>
        </div>

        <div class="page-title mt-3">Novo <span>Agendamento</span></div>

        <div class="form-card">
            <form method="post" action="/agenda/criar">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Tipo</label>
                    <select name="Type" id="tipoSelect" class="form-select" required>
                        <option value="">Selecione...</option>
                        <option value="Treino">Treino</option>
                        <option value="Refeicao">Refeição</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Título</label>
                    <input type="text" name="Title" class="form-control" placeholder="Ex: Treino de Peito" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Data e Hora</label>
                    <input type="datetime-local" name="Date" class="form-control"
                           value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                </div>

                <div id="sessaoGroup" class="mb-3">
                    <label class="form-label">Sessão de Treino (opcional)</label>
                    <select name="WorkoutSessionId" class="form-select">
                        <option value="">Nenhuma</option>
                        @foreach (var s in sessions)
                        {
                            <option value="@s.Id">@s.WorkoutPlan?.Name — @s.Name (@s.DayOfWeek)</option>
                        }
                    </select>
                </div>

                <div id="refeicaoGroup" class="mb-3">
                    <label class="form-label">Refeição (opcional)</label>
                    <select name="MealId" class="form-select">
                        <option value="">Nenhuma</option>
                        @foreach (var m in meals)
                        {
                            <option value="@m.Id">@m.DietPlan?.Name — @m.Name</option>
                        }
                    </select>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-mw px-4">Agendar</button>
                    <a href="/agenda/index" class="btn btn-outline-mw px-4">Cancelar</a>
                </div>
            </form>
        </div>
    </div>

    <script>
        const tipo = document.getElementById('tipoSelect');
        const sessaoG = document.getElementById('sessaoGroup');
        const refeicaoG = document.getElementById('refeicaoGroup');
        tipo.addEventListener('change', () => {
            sessaoG.style.display  = tipo.value === 'Treino'   ? 'block' : 'none';
            refeicaoG.style.display = tipo.value === 'Refeicao' ? 'block' : 'none';
        });
    </script>
</body>
</html>
